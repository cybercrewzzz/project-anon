// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum AccountStatus {
  active
  suspended
  banned
  deleted
}

enum Gender {
  male
  female
  other
  prefer_not_to_say
}

enum AgeRange {
  range_16_20
  range_21_26
  range_27_plus
}

enum VerificationStatus {
  pending
  approved
  rejected
}

enum UserProblemStatus {
  waiting
  matched
  expired
}

enum SessionStatus {
  active
  completed
  cancelled_grace
  cancelled_timeout
  cancelled_disconnect
  cancelled_admin
}

enum ReportStatus {
  pending
  reviewing
  resolved
  dismissed
}

enum ActionType {
  warning
  mute
  suspend
  ban
}

enum ReportCategory {
  harassment
  spam
  inappropriate_content
  impersonation
  other
}

enum Platform {
  ios
  android
  web
}

// ─── Account & Auth ─────────────────────────────────────────────────────────

model Account {
  accountId           String        @id @default(uuid()) @map("account_id") @db.Uuid
  email               String        @unique @db.VarChar(255)
  passwordHash        String?       @map("password_hash") @db.VarChar(255)
  oauthProvider       String?       @map("oauth_provider") @db.VarChar(50)
  oauthId             String?       @map("oauth_id") @db.VarChar(255)
  name                String?       @db.VarChar(100)
  nickname            String?       @unique @db.VarChar(50)
  ageRange            AgeRange?     @map("age_range")
  gender              Gender        @default(prefer_not_to_say)
  interfaceLanguageId String?       @map("interface_language_id") @db.Uuid
  status              AccountStatus @default(active)
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  deletedAt           DateTime?     @map("deleted_at")

  // Relations
  interfaceLanguage        Language?                 @relation("InterfaceLanguage", fields: [interfaceLanguageId], references: [languageId])
  accountRoles             AccountRole[]
  accountLanguages         AccountLanguage[]
  refreshTokens            RefreshToken[]
  deviceTokens             DeviceToken[]
  volunteerProfile         VolunteerProfile?
  volunteerExperience      VolunteerExperience?
  userPoints               UserPoints?
  userProblems             UserProblem[]
  seekerSessions           ChatSession[]             @relation("SeekerSessions")
  listenerSessions         ChatSession[]             @relation("ListenerSessions")
  reportsFiled             Report[]                  @relation("ReportsFiled")
  reportsReceived          Report[]                  @relation("ReportsReceived")
  blocksInitiated          Blocklist[]               @relation("BlocksInitiated")
  blocksReceived           Blocklist[]               @relation("BlocksReceived")
  actionsReceived          AccountAction[]           @relation("ActionsReceived")
  actionsPerformed         AccountAction[]           @relation("ActionsPerformed")
  volunteerSpecialisations VolunteerSpecialisation[]
  volunteerVerifications   VolunteerVerification[]   @relation("VolunteerVerifications")
  verificationsReviewed    VolunteerVerification[]   @relation("VerificationsReviewed")
  rolesAssigned            AccountRole[]             @relation("RolesAssignedBy")

  @@index([status])
  @@index([interfaceLanguageId])
  @@index([oauthProvider, oauthId])
  @@unique([oauthProvider, oauthId])
  @@map("account")
}

model Role {
  roleId      String   @id @default(uuid()) @map("role_id") @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")

  accountRoles    AccountRole[]
  rolePermissions RolePermission[]

  @@map("role")
}

model Permission {
  permissionId String   @id @default(uuid()) @map("permission_id") @db.Uuid
  name         String   @unique @db.VarChar(100)
  description  String?  @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permission")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [roleId])
  permission Permission @relation(fields: [permissionId], references: [permissionId])

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permission")
}

model AccountRole {
  accountId  String   @map("account_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedBy String?  @map("assigned_by") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  account           Account  @relation(fields: [accountId], references: [accountId])
  role              Role     @relation(fields: [roleId], references: [roleId])
  assignedByAccount Account? @relation("RolesAssignedBy", fields: [assignedBy], references: [accountId])

  @@id([accountId, roleId])
  @@index([roleId])
  @@index([assignedBy])
  @@map("account_role")
}

model AccountAction {
  actionId   String     @id @default(uuid()) @map("action_id") @db.Uuid
  accountId  String     @map("account_id") @db.Uuid
  adminId    String     @map("admin_id") @db.Uuid
  reportId   String?    @map("report_id") @db.Uuid
  actionType ActionType @map("action_type")
  reason     String?    @db.VarChar(300)
  createdAt  DateTime   @default(now()) @map("created_at")
  expiresAt  DateTime?  @map("expires_at")

  account Account @relation("ActionsReceived", fields: [accountId], references: [accountId])
  admin   Account @relation("ActionsPerformed", fields: [adminId], references: [accountId])
  report  Report? @relation(fields: [reportId], references: [reportId])

  @@index([accountId])
  @@index([adminId])
  @@index([reportId])
  @@map("account_action")
}

model RefreshToken {
  tokenId   String   @id @default(uuid()) @map("token_id") @db.Uuid
  accountId String   @map("account_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  familyId  String   @map("family_id") @db.Uuid

  account Account @relation(fields: [accountId], references: [accountId])

  @@index([accountId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_token")
}

model DeviceToken {
  deviceId     String   @id @default(uuid()) @map("device_id") @db.Uuid
  accountId    String   @map("account_id") @db.Uuid
  fcmToken     String   @map("fcm_token") @db.VarChar(255)
  platform     Platform
  lastActiveAt DateTime @default(now()) @map("last_active_at")

  account Account @relation(fields: [accountId], references: [accountId])

  @@index([accountId])
  @@map("device_token")
}

// ─── Language ───────────────────────────────────────────────────────────────

model Language {
  languageId String @id @default(uuid()) @map("language_id") @db.Uuid
  code       String @unique @db.VarChar(2)
  name       String @db.VarChar(50)

  accountsUsingAsInterface Account[]         @relation("InterfaceLanguage")
  accountLanguages         AccountLanguage[]

  @@map("language")
}

model AccountLanguage {
  accountId  String @map("account_id") @db.Uuid
  languageId String @map("language_id") @db.Uuid

  account  Account  @relation(fields: [accountId], references: [accountId])
  language Language @relation(fields: [languageId], references: [languageId])

  @@id([accountId, languageId])
  @@index([languageId])
  @@map("account_language")
}

// ─── Category & User Problem ────────────────────────────────────────────────

model Category {
  categoryId  String  @id @default(uuid()) @map("category_id") @db.Uuid
  name        String  @unique @db.VarChar(100)
  description String? @db.VarChar(200)

  userProblems UserProblem[]

  @@map("category")
}

model UserProblem {
  problemId           String            @id @default(uuid()) @map("problem_id") @db.Uuid
  accountId           String            @map("account_id") @db.Uuid
  categoryId          String            @map("category_id") @db.Uuid
  customCategoryLabel String?           @map("custom_category_label") @db.VarChar(100)
  feelingLevel        Int               @map("feeling_level") @db.SmallInt
  status              UserProblemStatus @default(waiting)
  createdAt           DateTime          @default(now()) @map("created_at")

  account      Account       @relation(fields: [accountId], references: [accountId])
  category     Category      @relation(fields: [categoryId], references: [categoryId])
  chatSessions ChatSession[]

  @@index([accountId])
  @@index([categoryId])
  @@index([status])
  @@map("user_problem")
}

model UserPoints {
  accountId   String   @id @map("account_id") @db.Uuid
  points      Int      @default(0)
  level       Int      @default(1) @db.SmallInt
  lastUpdated DateTime @default(now()) @map("last_updated")

  account Account @relation(fields: [accountId], references: [accountId])

  @@map("user_points")
}

// ─── Volunteer ──────────────────────────────────────────────────────────────

model VolunteerProfile {
  accountId           String             @id @map("account_id") @db.Uuid
  instituteEmail      String?            @map("institute_email") @db.VarChar(255)
  instituteName       String?            @map("institute_name") @db.VarChar(100)
  studentId           String?            @map("student_id") @db.VarChar(50)
  instituteIdImageUrl String?            @map("institute_id_image_url") @db.Text
  grade               String?            @db.VarChar(20)
  about               String?            @db.VarChar(500)
  verificationStatus  VerificationStatus @default(pending) @map("verification_status")
  isAvailable         Boolean            @default(false) @map("is_available")

  account Account @relation(fields: [accountId], references: [accountId])

  @@index([verificationStatus])
  @@index([isAvailable])
  @@map("volunteer_profile")
}

model VolunteerExperience {
  accountId   String   @id @map("account_id") @db.Uuid
  points      Int      @default(0)
  level       Int      @default(1) @db.SmallInt
  lastUpdated DateTime @default(now()) @map("last_updated")

  account Account @relation(fields: [accountId], references: [accountId])

  @@map("volunteer_experience")
}

model Specialisation {
  specialisationId String  @id @default(uuid()) @map("specialisation_id") @db.Uuid
  name             String  @unique @db.VarChar(50)
  description      String? @db.VarChar(300)

  volunteerSpecialisations VolunteerSpecialisation[]

  @@map("specialisation")
}

model VolunteerSpecialisation {
  accountId        String @map("account_id") @db.Uuid
  specialisationId String @map("specialisation_id") @db.Uuid

  account        Account        @relation(fields: [accountId], references: [accountId])
  specialisation Specialisation @relation(fields: [specialisationId], references: [specialisationId])

  @@id([accountId, specialisationId])
  @@index([specialisationId])
  @@map("volunteer_specialisation")
}

model VolunteerVerification {
  requestId   String             @id @default(uuid()) @map("request_id") @db.Uuid
  volunteerId String             @map("volunteer_id") @db.Uuid
  documentUrl String?            @map("document_url") @db.Text
  status      VerificationStatus @default(pending)
  adminNotes  String?            @map("admin_notes") @db.VarChar(300)
  reviewedBy  String?            @map("reviewed_by") @db.Uuid
  submittedAt DateTime           @default(now()) @map("submitted_at")
  reviewedAt  DateTime?          @map("reviewed_at")

  volunteer Account  @relation("VolunteerVerifications", fields: [volunteerId], references: [accountId])
  reviewer  Account? @relation("VerificationsReviewed", fields: [reviewedBy], references: [accountId])

  @@index([volunteerId])
  @@index([status])
  @@index([reviewedBy])
  @@map("volunteer_verification")
}

// ─── Chat Session ───────────────────────────────────────────────────────────

model ChatSession {
  sessionId       String        @id @default(uuid()) @map("session_id") @db.Uuid
  seekerId        String        @map("seeker_id") @db.Uuid
  listenerId      String?       @map("listener_id") @db.Uuid
  problemId       String        @map("problem_id") @db.Uuid
  startedAt       DateTime      @default(now()) @map("started_at")
  endedAt         DateTime?     @map("ended_at")
  userRating      Int?          @map("user_rating") @db.SmallInt
  volunteerRating Int?          @map("volunteer_rating") @db.SmallInt
  starredByUser   Boolean       @default(false) @map("starred_by_user")
  status          SessionStatus @default(active)
  closedReason    String?       @map("closed_reason") @db.VarChar(50)

  seeker   Account     @relation("SeekerSessions", fields: [seekerId], references: [accountId])
  listener Account?    @relation("ListenerSessions", fields: [listenerId], references: [accountId])
  problem  UserProblem @relation(fields: [problemId], references: [problemId])
  reports  Report[]

  @@index([seekerId])
  @@index([listenerId])
  @@index([problemId])
  @@index([status])
  @@index([startedAt])
  @@map("chat_session")
}

// ─── Report & Block ─────────────────────────────────────────────────────────

model Report {
  reportId    String         @id @default(uuid()) @map("report_id") @db.Uuid
  sessionId   String         @map("session_id") @db.Uuid
  reporterId  String         @map("reporter_id") @db.Uuid
  reportedId  String         @map("reported_id") @db.Uuid
  category    ReportCategory
  description String?        @db.VarChar(500)
  status      ReportStatus   @default(pending)
  reportedAt  DateTime       @default(now()) @map("reported_at")
  resolvedAt  DateTime?      @map("resolved_at")

  session  ChatSession     @relation(fields: [sessionId], references: [sessionId])
  reporter Account         @relation("ReportsFiled", fields: [reporterId], references: [accountId])
  reported Account         @relation("ReportsReceived", fields: [reportedId], references: [accountId])
  actions  AccountAction[]

  @@index([sessionId])
  @@index([reporterId])
  @@index([reportedId])
  @@index([status])
  @@unique([sessionId, reporterId])
  @@map("report")
}

model Blocklist {
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  blockedAt DateTime @default(now()) @map("blocked_at")

  blocker Account @relation("BlocksInitiated", fields: [blockerId], references: [accountId])
  blocked Account @relation("BlocksReceived", fields: [blockedId], references: [accountId])

  @@id([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocklist")
}
